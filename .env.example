# Optional Ops API tokens for capabilities probe (L0 auth check).
# Copy from bifrost-trade-infra/config/config.dev.yaml ops.auth.tokens
BIFROST_DEV_OPS_TOKEN=
BIFROST_PROD_OPS_TOKEN=

# Platform API listen address (default :8780)
# PLATFORM_LISTEN=:8780

# Platform L1 actuation auth (operator can restart/scale/delete cluster workloads)
PLATFORM_OPERATOR_TOKEN=
VITE_PLATFORM_OPERATOR_TOKEN=

# Admin token for cluster add-ons (metrics-server ensure)
PLATFORM_ADMIN_TOKEN=

# Layer A metrics-server install via platform-api (exec install-metrics-server.sh)
PLATFORM_METRICS_SERVER_ENABLED=1
# PLATFORM_METRICS_SERVER_SCRIPT=

# Layer B observability deep links (optional; override clusters.yaml observability_urls)
# PLATFORM_GRAFANA_URL=http://192.168.10.73:3000
# PLATFORM_PROMETHEUS_URL=

# Path to environments config (default ./config/environments.yaml)
# PLATFORM_CONFIG=./config/environments.yaml

# Kubernetes cluster probe (L0) — local kubeconfig for platform-api
PLATFORM_KUBECONFIG=~/.kube/bifrost-k3s.yaml


# Sync kubeconfig from K3s server (sibling repo bifrost-trade-infra)
PLATFORM_CLUSTER_SYNC_ENABLED=1
# Absolute path recommended; run_platform.py also auto-resolves sibling infra/scripts/k3s/fetch-kubeconfig.sh
PLATFORM_CLUSTER_SYNC_SCRIPT=

# AI Auto-Remediation sidecar (Cursor SDK runner on :8781)
# CURSOR_API_KEY=
# REMEDIATION_RUNNER_URL=http://127.0.0.1:8781
# REMEDIATION_RUNNER_AUTOSTART=1  # make start auto-starts local runner when URL is localhost
# REMEDIATION_RUNNER_PORT=8781
# REMEDIATION_RUNNER_BIND=127.0.0.1
#   On Mac Mini agent host use 0.0.0.0 so Mac Pro platform-api can reach runner:
#   REMEDIATION_RUNNER_BIND=0.0.0.0
#   Mac Pro .env: REMEDIATION_RUNNER_URL=http://192.168.10.50:8781
# Agent Desk → Update agent on Mini (runs deploy_mac_mini.sh from platform-api host):
# AGENT_DEPLOY_ENABLED=1
# AGENT_DEPLOY_REMOTE=vision@192.168.10.50
# Do not put inline comments on the same line as AGENT_DEPLOY_REMOTE (use a separate # line).
# Optional Hermes Gateway MCP (agent host) — bridge probes when set:
# HERMES_MCP_URL=http://192.168.10.50:8642/mcp
# REMEDIATION_CWD=../bifrost-trade-infra
# REMEDIATION_MODEL=composer-2.5
# NIGHTLY_SKIP_CLUSTER=0
# Mac Pro dev nightly-agent + Mini proposal POST:
# PLATFORM_API_URL=http://127.0.0.1:8780
# Mini agent host env.sh: PLATFORM_API_URL=http://192.168.10.73:30878 (or Mac Pro LAN :8780)
