{
  "comment": "Vision V5 — unified Cursor MCP: Dev + Ops + Business in one window",
  "mcpServers": {
    "bifrost-platform": {
      "command": "npx",
      "args": ["tsx", "mcp/platform/src/index.ts"],
      "env": {
        "PLATFORM_API_URL": "http://127.0.0.1:8780",
        "PLATFORM_OPERATOR_TOKEN": "<operator-or-admin-token>"
      }
    },
    "bifrost-trade-api": {
      "command": "npx",
      "args": ["tsx", "mcp/trade/src/index.ts"],
      "env": {
        "TRADE_API_GATEWAY": "http://192.168.10.73:30880",
        "TRADE_AGENT_CATALOG_URL": "http://127.0.0.1:8780/api/v1/trade-agent/catalog"
      }
    }
  }
}
